generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(uuid())
  name              String?
  email             String              @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  resetToken        String?             @unique
  resetTokenExpiry  DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  sessionDuration   Int                 @default(7)
  autoLogoutMinutes Int                 @default(30)
  darkMode          Boolean             @default(false)
  currency          String              @default("BRL")
  timezone          String              @default("America/Sao_Paulo")
  role              Role                @default(USER)
  plan              Plan                @default(FREE)
  contas            Conta[]
  accounts          Account[]
  auditLogs         AuditLog[]
  categories        Category[]
  debts             Debt[]
  notificationPrefs NotificationPref?
  purchases         Purchase[]
  sessions          Session[]
  transactions      Transaction[]
  reportHistories   ReportHistory[]
  metas             Meta[]
  assinaturas       Assinatura[]
  lembretes         Lembrete[]
  estoque           Estoque[]
  listasCompra      ListaCompra[]
  vendas            Venda[]
  assets            Asset[]
  notifications     Notification[]
  ItemImportMapping ItemImportMapping[]
  bankItems         BankItem[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Conta {
  id            String        @id @default(uuid())
  userId        String
  name          String
  type          AccountType
  balance       Int           @default(0)
  color         String        @default("#047857")
  icon          String?
  isActive      Boolean       @default(true)
  diaFechamento Int? // Cartão: dia do fechamento da fatura
  diaVencimento Int? // Cartão: dia do vencimento
  limiteCredito Int? // Cartão: limite total em centavos
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  isArchived    Boolean       @default(false)
  archivedAt    DateTime?
  isDeleted     Boolean       @default(false)
  deletedAt     DateTime?

  // Integração Bancária
  provider      String? // Ex: "PLUGGY"
  externalId    String? // ID da conta no provedor externo
  lastSync      DateTime?

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  debts         Debt[]
  purchases     Purchase[]
  transactions  Transaction[]
  assinaturas   Assinatura[]
  vendas        Venda[]

  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id           String          @id @default(uuid())
  userId       String
  name         String
  type         TransactionType
  color        String          @default("#047857")
  icon         String?
  parentId     String?
  budgetLimit  Int?
  isActive     Boolean         @default(true)
  isArchived   Boolean         @default(false)
  archivedAt   DateTime?
  isDeleted    Boolean         @default(false)
  deletedAt    DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  parent       Category?       @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]      @relation("CategoryHierarchy")
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  debts        Debt[]
  purchases    Purchase[]
  transactions Transaction[]
  metas        Meta[]
  assinaturas  Assinatura[]

  @@index([userId])
  @@index([parentId])
}

model Transaction {
  id                 String            @id @default(uuid())
  userId             String
  accountId          String
  categoryId         String
  description        String            @db.VarChar(200)
  amount             Int
  type               TransactionType
  status             TransactionStatus
  occurrenceDate     DateTime
  dueDate            DateTime?
  paidAt             DateTime?
  isRecurring        Boolean           @default(false)
  recurrenceType     RecurrenceType?
  recurrenceDay      Int?
  isInstallment      Boolean           @default(false)
  installmentTotal   Int?
  installmentCurrent Int?
  installmentId      String?
  receiptUrl         String?
  notes              String?
  isReconciled       Boolean           @default(false)
  reconciledAt       DateTime?
  isArchived         Boolean           @default(false)
  archivedAt         DateTime?
  isDeleted          Boolean           @default(false)
  deletedAt          DateTime?
  transactionId      String?           @unique
  externalId         String?           @unique // ID da transação no provedor externo
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  account            Conta           @relation(fields: [accountId], references: [id])
  category           Category          @relation(fields: [categoryId], references: [id])
  purchase           Purchase?         @relation(fields: [transactionId], references: [id])
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([occurrenceDate])
  @@index([status])
  @@index([isDeleted])
}

model Debt {
  id               String            @id @default(uuid())
  userId           String
  accountId        String
  categoryId       String
  name             String            @db.VarChar(100)
  totalAmount      Int
  installmentValue Int
  installmentTotal Int
  installmentPaid  Int               @default(0)
  interestRate     Decimal?          @db.Decimal(5, 2)
  amortizationType AmortizationType?
  allowsPrepayment Boolean           @default(true)
  startDate        DateTime
  nextDueDate      DateTime
  endDate          DateTime?
  status           DebtStatus
  isPaidOff        Boolean           @default(false)
  paidOffAt        DateTime?
  creditor         String?           @db.VarChar(100)
  isArchived       Boolean           @default(false)
  archivedAt       DateTime?
  isDeleted        Boolean           @default(false)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  account          Conta           @relation(fields: [accountId], references: [id])
  category         Category          @relation(fields: [categoryId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Purchase {
  id               String         @id @default(uuid())
  userId           String
  description      String         @db.VarChar(200)
  totalAmount      Int
  purchaseDate     DateTime
  storeName        String?        @db.VarChar(100)
  storeLocation    String?
  paymentMethod    PaymentMethod
  accountId        String?
  categoryId       String?
  isInstallment    Boolean        @default(false)
  installmentTotal Int?
  installmentValue Int?
  receiptUrl       String?
  receiptXml       String?
  isCompleted      Boolean        @default(true)
  transactionId    String?
  isArchived       Boolean        @default(false)
  archivedAt       DateTime?
  isDeleted        Boolean        @default(false)
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  account          Conta?       @relation(fields: [accountId], references: [id])
  category         Category?      @relation(fields: [categoryId], references: [id])
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items            PurchaseItem[]
  transaction      Transaction?

  @@index([userId])
  @@index([purchaseDate])
}

model PurchaseItem {
  id               String    @id @default(uuid())
  purchaseId       String
  name             String    @db.VarChar(200)
  quantity         Decimal   @db.Decimal(10, 2)
  unit             String?
  unitPrice        Int
  totalPrice       Int
  category         String?
  barcode          String?
  lastPrice        Int?
  lastPurchaseDate DateTime?
  createdAt        DateTime  @default(now())
  purchase         Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([name])
}

model ItemImportMapping {
  id             String   @id @default(uuid())
  userId         String
  itemPattern    String   @db.VarChar(255)
  itemNormalized String   @db.VarChar(255)
  categoryId     String?
  accountId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemNormalized])
  @@index([userId])
  @@index([itemNormalized])
}

model NotificationPref {
  id                String   @id @default(uuid())
  userId            String   @unique
  emailEnabled      Boolean  @default(true)
  pushEnabled       Boolean  @default(true)
  pushToken         String?  @db.Text // P14: Armazena subscrição WebPush
  budgetAlert       Boolean  @default(true)
  dueDateAlert      Boolean  @default(true)
  dueDateDaysBefore Int      @default(3)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String   @db.VarChar(100)
  entityType String   @db.VarChar(50)
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  DEBIT_CARD
  CASH
  INVESTMENT
  PIX
  OTHER
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  PAID
  CANCELLED
}

enum RecurrenceType {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

model ReportHistory {
  id         String     @id @default(uuid())
  userId     String
  type       ReportType
  parameters Json?
  fileUrl    String?
  fileName   String
  status     LogStatus  @default(GENERATED)
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum ReportType {
  FINANCIAL_MONTHLY
  CATEGORY_ANALYSIS
  TRANSACTION_HISTORY
}

enum LogStatus {
  GENERATED
  FAILED
  PROCESSING
}

enum DebtStatus {
  ACTIVE
  PAID
  CANCELLED
}

enum AmortizationType {
  SAC
  PRICE
  FIXED
}

enum PaymentMethod {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  PIX
  BANK_TRANSFER
  OTHER
}

enum RolloverType {
  NEXT_MONTH
  INVESTMENT
  DEBT_PAYOFF
  NONE
}

// ============================================
// NOVAS ENTIDADES — EXPANSÃO ENTERPRISE
// ============================================

model Meta {
  id            String    @id @default(uuid())
  usuarioId     String
  nome          String    @db.VarChar(100)
  descricao     String?
  valorAlvo     Int // em centavos
  montanteAtual Int       @default(0)
  prazo         DateTime?
  categoriaId   String?
  icone         String?
  cor           String    @default("#10B981")
  concluida     Boolean   @default(false)
  concluidaEm   DateTime?
  isArchived    Boolean   @default(false)
  archivedAt    DateTime?
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt
  usuario       User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria     Category? @relation(fields: [categoriaId], references: [id])

  @@index([usuarioId])
}

model Assinatura {
  id               String          @id @default(uuid())
  usuarioId        String
  nome             String          @db.VarChar(100)
  descricao        String?
  valor            Int // em centavos
  ciclo            CicloAssinatura
  proximaRenovacao DateTime
  categoriaId      String?
  contaId          String?
  ativa            Boolean         @default(true)
  canceladaEm      DateTime?
  isArchived       Boolean         @default(false)
  archivedAt       DateTime?
  isDeleted        Boolean         @default(false)
  deletedAt        DateTime?
  criadoEm         DateTime        @default(now())
  atualizadoEm     DateTime        @updatedAt
  usuario          User            @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria        Category?       @relation(fields: [categoriaId], references: [id])
  conta            Conta?        @relation(fields: [contaId], references: [id])

  @@index([usuarioId])
  @@index([proximaRenovacao])
}

model Lembrete {
  id                   String       @id @default(uuid())
  usuarioId            String
  titulo               String       @db.VarChar(200)
  mensagem             String?
  tipo                 TipoLembrete
  diasAntesDeNotificar Int          @default(3)
  notificarEm          DateTime
  lido                 Boolean      @default(false)
  lidoEm               DateTime?
  url                  String? // P14: Link para ação direta
  referenciaId         String? // ID genérico da entidade (transação, dívida, etc.)
  referenciaTipo       String? // "TRANSACAO", "DIVIDA", "ASSINATURA", "META", "ESTOQUE"
  criadoEm             DateTime     @default(now())
  usuario              User         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([notificarEm])
  @@index([lido])
}

enum CicloAssinatura {
  SEMANAL
  QUINZENAL
  MENSAL
  BIMESTRAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

enum TipoLembrete {
  VENCIMENTO_DIVIDA
  ALERTA_ORCAMENTO
  RENOVACAO_ASSINATURA
  PROGRESSO_META
  VENCIMENTO_TRANSACAO
  ALERTA_LIMITE_CARTAO
  ALERTA_ESTOQUE
  ALERTA_VALIDADE
  GERAL
}

// ============================================
// MERCADO / FEIRA — CONTROLE DE ESTOQUE
// ============================================

model Estoque {
  id            String      @id @default(uuid())
  usuarioId     String
  produtoId     String? // Referência ao produto do catálogo
  nome          String      @db.VarChar(200)
  categoria     String?     @db.VarChar(100)
  quantidade    Decimal     @default(0) @db.Decimal(10, 2)
  unidade       String      @default("un")
  precoMedio    Int         @default(0) // em centavos
  precoUltimo   Int         @default(0)
  ultimaCompra  DateTime?
  validade      DateTime?
  estoqueMinimo Decimal     @default(1) @db.Decimal(10, 2)
  barcode       String?     @db.VarChar(50)
  tipo          EstoqueTipo @default(PESSOAL)
  isArchived    Boolean     @default(false)
  archivedAt    DateTime?
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?
  ativo         Boolean     @default(true)
  criadoEm      DateTime    @default(now())
  atualizadoEm  DateTime    @updatedAt
  usuario       User        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  vendas        Venda[]

  @@index([usuarioId])
  @@index([categoria])
  @@index([barcode])
  @@index([tipo])
}

enum EstoqueTipo {
  PESSOAL
  COMERCIAL
}

model Venda {
  id         String   @id @default(uuid())
  usuarioId  String
  estoqueId  String
  quantidade Decimal  @db.Decimal(10, 2)
  valorVenda Int // em centavos
  custoVenda Int // em centavos (fixado no momento da venda para histórico)
  lucro      Int // em centavos
  dataVenda  DateTime @default(now())
  contaId    String? // Conta onde entrou o dinheiro
  vendaId    String?  @unique // ID externo ou link com transação

  usuario User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  estoque Estoque  @relation(fields: [estoqueId], references: [id])
  account Conta? @relation(fields: [contaId], references: [id])

  @@index([usuarioId])
  @@index([dataVenda])
}

// ============================================
// PATRIMÔNIO — GESTÃO DE BENS E ATIVOS
// ============================================

model Asset {
  id          String    @id @default(uuid())
  usuarioId   String
  nome        String    @db.VarChar(200)
  descricao   String?   @db.Text
  tipo        AssetType @default(OUTROS)
  valorCompra Int       @default(0) // em centavos
  valorAtual  Int       @default(0) // em centavos
  dataCompra  DateTime?
  instituicao String?   @db.VarChar(100) // ex: Imobiliária, Concessionária, Corretora
  cor         String    @default("#047857")
  icone       String?

  // Governança P2
  isArchived Boolean   @default(false)
  archivedAt DateTime?
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario User @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([tipo])
}

enum AssetType {
  IMOVEL
  VEICULO
  INVESTIMENTO_FIXO
  EQUIPAMENTO
  JOIA_ARTE
  OUTROS
}

// Catálogo de produtos do atacarejo
model Produto {
  id         String   @id @default(uuid())
  nome       String   @unique @db.VarChar(200)
  categoria  String   @db.VarChar(100)
  unidade    String   @default("un")
  precoMedio Int      @default(0) // em centavos
  barcode    String?  @unique @db.VarChar(50)
  imagem     String? // URL da imagem
  popular    Boolean  @default(false) // itens mais comuns
  criadoEm   DateTime @default(now())

  @@index([categoria])
  @@index([barcode])
  @@index([popular])
}

model ListaCompra {
  id          String            @id @default(uuid())
  usuarioId   String
  nome        String            @db.VarChar(200)
  concluida   Boolean           @default(false)
  concluidaEm DateTime?
  criadoEm    DateTime          @default(now())
  usuario     User              @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  itens       ListaCompraItem[]

  @@index([usuarioId])
}

model ListaCompraItem {
  id          String      @id @default(uuid())
  listaId     String
  nome        String      @db.VarChar(200)
  quantidade  Decimal     @default(1) @db.Decimal(10, 2)
  unidade     String      @default("un")
  comprado    Boolean     @default(false)
  precoMaximo Int? // em centavos
  observacao  String?
  ordem       Int         @default(0)
  criadoEm    DateTime    @default(now())
  lista       ListaCompra @relation(fields: [listaId], references: [id], onDelete: Cascade)

  @@index([listaId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// BANKING — INTEGRAÇÃO AUTOMÁTICA (Pluggy)
// ============================================

model BankItem {
  id               String      @id @default(uuid())
  userId           String
  externalId       String      @unique // ID do Item no Pluggy
  providerId       String? // ID do Conector (ex: 1 = Nubank)
  providerName     String? // Nome do Banco
  providerImageUrl String?
  status           String      @default("UPDATED") // UPDATED, UPDATING, LOGIN_ERROR, WAITING_USER_INPUT
  consentExpiresAt DateTime?
  lastSyncAt       DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([externalId])
}
