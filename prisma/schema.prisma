generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(uuid())
  name              String?
  email             String            @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  sessionDuration   Int               @default(7)
  autoLogoutMinutes Int               @default(30)
  darkMode          Boolean           @default(false)
  currency          String            @default("BRL")
  timezone          String            @default("America/Sao_Paulo")
  accounts          Account[]
  auditLogs         AuditLog[]
  budgets           Budget[]
  categories        Category[]
  debts             Debt[]
  notificationPrefs NotificationPref?
  purchases         Purchase[]
  sessions          Session[]
  transactions      Transaction[]
  reportHistories   ReportHistory[]
  metas             Meta[]
  assinaturas       Assinatura[]
  lembretes         Lembrete[]
  estoque           Estoque[]
  listasCompra      ListaCompra[]
}

model Account {
  id              String        @id @default(uuid())
  userId          String
  name            String
  type            AccountType
  balance         Int           @default(0)
  color           String        @default("#047857")
  icon            String?
  isActive        Boolean       @default(true)
  diaFechamento   Int?          // Cartão: dia do fechamento da fatura
  diaVencimento   Int?          // Cartão: dia do vencimento
  limiteCredito   Int?          // Cartão: limite total em centavos
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  debts           Debt[]
  purchases       Purchase[]
  transactions    Transaction[]
  assinaturas     Assinatura[]

  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id           String          @id @default(uuid())
  userId       String
  name         String
  type         TransactionType
  color        String          @default("#047857")
  icon         String?
  parentId     String?
  budgetLimit  Int?
  isActive     Boolean         @default(true)
  isArchived   Boolean         @default(false)
  archivedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  parent       Category?       @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]      @relation("CategoryHierarchy")
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  debts        Debt[]
  purchases    Purchase[]
  transactions Transaction[]
  metas        Meta[]
  assinaturas  Assinatura[]

  @@index([userId])
  @@index([parentId])
}

model Transaction {
  id                 String            @id @default(uuid())
  userId             String
  accountId          String
  categoryId         String
  description        String            @db.VarChar(200)
  amount             Int
  type               TransactionType
  status             TransactionStatus
  occurrenceDate     DateTime
  dueDate            DateTime?
  paidAt             DateTime?
  isRecurring        Boolean           @default(false)
  recurrenceType     RecurrenceType?
  recurrenceDay      Int?
  isInstallment      Boolean           @default(false)
  installmentTotal   Int?
  installmentCurrent Int?
  installmentId      String?
  receiptUrl         String?
  notes              String?
  isReconciled       Boolean           @default(false)
  reconciledAt       DateTime?
  isDeleted          Boolean           @default(false)
  deletedAt          DateTime?
  transactionId      String?           @unique
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  account            Account           @relation(fields: [accountId], references: [id])
  category           Category          @relation(fields: [categoryId], references: [id])
  purchase           Purchase?         @relation(fields: [transactionId], references: [id])
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([occurrenceDate])
  @@index([status])
  @@index([isDeleted])
}

model Debt {
  id               String            @id @default(uuid())
  userId           String
  accountId        String
  categoryId       String
  name             String            @db.VarChar(100)
  totalAmount      Int
  installmentValue Int
  installmentTotal Int
  installmentPaid  Int               @default(0)
  interestRate     Decimal?          @db.Decimal(5, 2)
  amortizationType AmortizationType?
  allowsPrepayment Boolean           @default(true)
  startDate        DateTime
  nextDueDate      DateTime
  endDate          DateTime?
  status           DebtStatus
  isPaidOff        Boolean           @default(false)
  paidOffAt        DateTime?
  creditor         String?           @db.VarChar(100)
  isDeleted        Boolean           @default(false)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  account          Account           @relation(fields: [accountId], references: [id])
  category         Category          @relation(fields: [categoryId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Purchase {
  id               String         @id @default(uuid())
  userId           String
  description      String         @db.VarChar(200)
  totalAmount      Int
  purchaseDate     DateTime
  storeName        String?        @db.VarChar(100)
  storeLocation    String?
  paymentMethod    PaymentMethod
  accountId        String?
  categoryId       String?
  isInstallment    Boolean        @default(false)
  installmentTotal Int?
  installmentValue Int?
  receiptUrl       String?
  receiptXml       String?
  budgetId         String?
  isCompleted      Boolean        @default(true)
  transactionId    String?
  isDeleted        Boolean        @default(false)
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  account          Account?       @relation(fields: [accountId], references: [id])
  budget           Budget?        @relation(fields: [budgetId], references: [id])
  category         Category?      @relation(fields: [categoryId], references: [id])
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items            PurchaseItem[]
  transaction      Transaction?

  @@index([userId])
  @@index([purchaseDate])
}

model PurchaseItem {
  id               String    @id @default(uuid())
  purchaseId       String
  name             String    @db.VarChar(200)
  quantity         Decimal   @db.Decimal(10, 2)
  unit             String?
  unitPrice        Int
  totalPrice       Int
  category         String?
  barcode          String?
  lastPrice        Int?
  lastPurchaseDate DateTime?
  createdAt        DateTime  @default(now())
  purchase         Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([name])
}

model Budget {
  id              String       @id @default(uuid())
  userId          String
  month           Int
  year            Int
  globalLimit     Int
  spentAmount     Int          @default(0)
  rolloverEnabled Boolean      @default(true)
  rolloverType    RolloverType @default(NEXT_MONTH)
  alertThreshold  Int          @default(80)
  alertEnabled    Boolean      @default(true)
  isDeleted       Boolean      @default(false)
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases       Purchase[]

  @@unique([userId, month, year])
  @@index([userId])
}

model NotificationPref {
  id                String   @id @default(uuid())
  userId            String   @unique
  emailEnabled      Boolean  @default(true)
  pushEnabled       Boolean  @default(true)
  budgetAlert       Boolean  @default(true)
  dueDateAlert      Boolean  @default(true)
  dueDateDaysBefore Int      @default(3)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String   @db.VarChar(100)
  entityType String   @db.VarChar(50)
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  DEBIT_CARD
  CASH
  INVESTMENT
  PIX
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  PAID
  CANCELLED
}

enum RecurrenceType {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

model ReportHistory {
  id           String      @id @default(uuid())
  userId       String
  type         ReportType
  parameters   Json?
  fileUrl      String?
  fileName     String
  status       LogStatus   @default(GENERATED)
  createdAt    DateTime    @default(now())
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum ReportType {
  FINANCIAL_MONTHLY
  CATEGORY_ANALYSIS
  TRANSACTION_HISTORY
}

enum LogStatus {
  GENERATED
  FAILED
  PROCESSING
}

enum DebtStatus {
  ACTIVE
  PAID
  CANCELLED
}

enum AmortizationType {
  SAC
  PRICE
  FIXED
}

enum PaymentMethod {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  PIX
  BANK_TRANSFER
  OTHER
}

enum RolloverType {
  NEXT_MONTH
  INVESTMENT
  DEBT_PAYOFF
  NONE
}

// ============================================
// NOVAS ENTIDADES — EXPANSÃO ENTERPRISE
// ============================================

model Meta {
  id            String    @id @default(uuid())
  usuarioId     String
  nome          String    @db.VarChar(100)
  descricao     String?
  valorAlvo     Int       // em centavos
  montanteAtual Int       @default(0)
  prazo         DateTime?
  categoriaId   String?
  icone         String?
  cor           String    @default("#10B981")
  concluida     Boolean   @default(false)
  concluidaEm   DateTime?
  excluida      Boolean   @default(false)
  excluidaEm    DateTime?
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt
  usuario       User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria     Category? @relation(fields: [categoriaId], references: [id])

  @@index([usuarioId])
}

model Assinatura {
  id               String          @id @default(uuid())
  usuarioId        String
  nome             String          @db.VarChar(100)
  descricao        String?
  valor            Int             // em centavos
  ciclo            CicloAssinatura
  proximaRenovacao DateTime
  categoriaId      String?
  contaId          String?
  ativa            Boolean         @default(true)
  canceladaEm      DateTime?
  excluida         Boolean         @default(false)
  excluidaEm       DateTime?
  criadoEm         DateTime        @default(now())
  atualizadoEm     DateTime        @updatedAt
  usuario          User            @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria        Category?       @relation(fields: [categoriaId], references: [id])
  conta            Account?        @relation(fields: [contaId], references: [id])

  @@index([usuarioId])
  @@index([proximaRenovacao])
}

model Lembrete {
  id                   String       @id @default(uuid())
  usuarioId            String
  titulo               String       @db.VarChar(200)
  mensagem             String?
  tipo                 TipoLembrete
  diasAntesDeNotificar Int          @default(3)
  notificarEm          DateTime
  lido                 Boolean      @default(false)
  lidoEm               DateTime?
  referenciaId         String?      // ID genérico da entidade (transação, dívida, etc.)
  referenciaTipo       String?      // "TRANSACAO", "DIVIDA", "ASSINATURA", "META"
  criadoEm             DateTime     @default(now())
  usuario              User         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([notificarEm])
  @@index([lido])
}

enum CicloAssinatura {
  SEMANAL
  QUINZENAL
  MENSAL
  BIMESTRAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

enum TipoLembrete {
  VENCIMENTO_DIVIDA
  ALERTA_ORCAMENTO
  RENOVACAO_ASSINATURA
  PROGRESSO_META
  VENCIMENTO_TRANSACAO
  ALERTA_LIMITE_CARTAO
  GERAL
}

// ============================================
// MERCADO / FEIRA — CONTROLE DE ESTOQUE
// ============================================

model Estoque {
  id            String    @id @default(uuid())
  usuarioId     String
  produtoId     String?   // Referência ao produto do catálogo
  nome          String    @db.VarChar(200)
  categoria     String?   @db.VarChar(100)
  quantidade    Decimal   @db.Decimal(10, 2) @default(0)
  unidade       String    @default("un")
  precoMedio     Int       @default(0) // em centavos
  precoUltimo    Int       @default(0)
  ultimaCompra  DateTime?
  validade      DateTime?
  estoqueMinimo Decimal   @db.Decimal(10, 2) @default(1)
  barcode       String?   @db.VarChar(50)
  ativo         Boolean   @default(true)
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt
  usuario       User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([categoria])
  @@index([barcode])
}

// Catálogo de produtos do atacarejo
model Produto {
  id            String    @id @default(uuid())
  nome          String    @unique @db.VarChar(200)
  categoria     String    @db.VarChar(100)
  unidade       String    @default("un")
  precoMedio    Int       @default(0) // em centavos
  barcode       String?   @unique @db.VarChar(50)
  imagem        String?   // URL da imagem
  popular       Boolean   @default(false) // itens mais comuns
  criadoEm      DateTime  @default(now())

  @@index([categoria])
  @@index([barcode])
  @@index([popular])
}

model ListaCompra {
  id            String    @id @default(uuid())
  usuarioId     String
  nome          String    @db.VarChar(200)
  concluida     Boolean   @default(false)
  concluidaEm   DateTime?
  criadoEm      DateTime  @default(now())
  usuario       User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  itens         ListaCompraItem[]

  @@index([usuarioId])
}

model ListaCompraItem {
  id            String    @id @default(uuid())
  listaId       String
  nome          String    @db.VarChar(200)
  quantidade    Decimal   @db.Decimal(10, 2) @default(1)
  unidade       String    @default("un")
  comprado      Boolean   @default(false)
  precoMaximo   Int?      // em centavos
  observacao    String?
  ordem         Int       @default(0)
  criadoEm      DateTime  @default(now())
  lista         ListaCompra @relation(fields: [listaId], references: [id], onDelete: Cascade)

  @@index([listaId])
}
