------MultipartBoundary--abNkzngqGstR9cddNr5Z27dmPpgoL0xTZ4RADkD8d2----
Content-Type: text/css
Content-Transfer-Encoding: binary
Content-Location: https://nfce.sefaz.pe.gov.br:444/nfce/css/consultaNfce.css

@charset "utf-8";

body, input, select, textarea, button, .ui-btn { font-size: 0.7em; line-height: 1.2em; font-family: Arial, Helvetica, sans-serif; }

.ui-header .ui-title, .ui-footer .ui-title { font-size: 1em; text-align: center; display: block; margin: 0px 0%; padding: 10px 0px 0px; text-overflow: ellipsis; overflow: hidden; white-space: normal; font-weight: bold; color: rgb(108, 108, 108); outline: 0px !important; }

.ui-overlay-a, .ui-page-theme-a, .ui-page-theme-a .ui-panel-wrapper { background-color: rgb(216, 216, 216); border-color: rgb(187, 187, 187); color: rgb(51, 51, 51); text-shadow: none; }

.ui-bar-a, .ui-page-theme-a .ui-bar-inherit, html .ui-bar-a .ui-bar-inherit, html .ui-body-a .ui-bar-inherit, html body .ui-group-theme-a .ui-bar-inherit { background-color: rgb(216, 216, 216); border-color: rgb(221, 221, 221); color: rgb(51, 51, 51); text-shadow: none; font-weight: 700; }

.ui-content { padding: 0.2em; }

.info { font-weight: normal; }

.txtCenter { text-align: center; }

.txtRight { text-align: right; }

#totalNota { max-width: 500px; margin-top: 15px; margin-left: auto; margin-right: auto; }

.totalNumb { min-width: 130px; float: right; }

#linhaTotal { padding: 5px 5px 5px 0px; border-top: 1px dotted rgb(204, 204, 204); height: auto; width: 99%; overflow: auto; line-height: normal; }

.ui-mobile label, .ui-controlgroup-label { display: inline; margin: 0px; }

.ui-mobile label, div.ui-controlgroup-label { font-weight: bold; font-size: 1em; }

#tabResult { max-width: 500px; margin-top: 15px; margin-left: auto; margin-right: auto; width: 100%; }

#tabResult tr td { padding: 5px; word-break: break-word; }

#tabResult tr.shade { background: rgb(239, 239, 239); }

#movie-table tr.shade { background: rgb(238, 249, 254); }

#linhaTotal label { color: rgb(102, 153, 204); font-size: 1em; }

#linhaTotal label.txtObs { color: rgb(153, 153, 153); display: block; margin-right: 112px; position: relative; }

#linhaTotal span.txtObs { color: rgb(153, 153, 153); display: block; margin-top: -15px; }

.txtTit { color: rgb(102, 153, 204); font-weight: bold; }

.txtItem { color: rgb(102, 153, 204); }

.txtTopo { font-size: 1.2em; color: rgb(102, 153, 204); font-weight: bold; line-height: 1.4em; }

.valor { font-size: 1.2em; }

.txtMax { font-size: 1.5em; color: rgb(102, 153, 204); font-weight: bold; }

.noWrap { white-space: nowrap; }

#conteudo { max-width: 500px; min-width: 300px; margin-top: 15px; margin-left: auto; margin-right: auto; background-color: rgb(255, 255, 255); padding: 5px; border-radius: 5px; }

.linhaShade { background: rgb(239, 239, 239); }

#infos { max-width: 510px; margin-top: 15px; margin-left: auto; margin-right: auto; }

.ui-listview > .ui-li-static, .ui-listview > .ui-li-divider, .ui-listview > li > a.ui-btn { margin: 0px; display: block; position: relative; text-align: left; text-overflow: ellipsis; overflow: hidden; white-space: normal; }

.ui-btn { font-size: 1em; }

.ui-collapsible-heading .ui-btn { padding-left: 36px; color: rgb(126, 126, 126); }

.RvlUnit { width: 100px; display: inline-table; color: rgb(137, 137, 137); white-space: nowrap; }

.Rqtd { width: 70px; display: inline-table; color: rgb(137, 137, 137); white-space: nowrap; }

.RCod { width: 120px; color: rgb(137, 137, 137); white-space: normal; padding-left: 2px; }

.RUN { width: 50px; display: inline-table; color: rgb(137, 137, 137); white-space: nowrap; }

.ui-collapsible-inset, .ui-collapsible-set { margin: 0.8em 0px; }

.ui-page-theme-a .ui-btn:focus, html .ui-bar-a .ui-btn:focus, html .ui-body-a .ui-btn:focus, html body .ui-group-theme-a .ui-btn:focus, html head + body .ui-btn.ui-btn-a:focus, .ui-page-theme-a .ui-focus, html .ui-bar-a .ui-focus, html .ui-body-a .ui-focus, html body .ui-group-theme-a .ui-focus, html head + body .ui-btn-a.ui-focus, html head + body .ui-body-a.ui-focus { box-shadow: rgb(51, 136, 204) 0px 0px 5px; }

.ui-table-reflow tbody th { margin-top: 0px; }

.ui-table-reflow td .ui-table-cell-label, .ui-table-reflow th .ui-table-cell-label { margin: -1em 0em -2em -0.8em; min-width: 15%; }

th.txtLeft { text-align: left; }

th { padding-right: 2px; color: rgb(137, 137, 137); font-weight: normal; }

#tabResult02 { max-width: 500px; margin-top: 15px; margin-left: auto; margin-right: auto; width: 100%; }

#tabResult02 tr td { padding: 5px; }

#tabResult02 tr.shade { background: rgb(239, 239, 239); }

.ui-page-theme-a .ui-btn, html .ui-bar-a .ui-btn, html .ui-body-a .ui-btn, html body .ui-group-theme-a .ui-btn, html head + body .ui-btn.ui-btn-a, .ui-page-theme-a .ui-btn:visited, html .ui-bar-a .ui-btn:visited, html .ui-body-a .ui-btn:visited, html body .ui-group-theme-a .ui-btn:visited, html head + body .ui-btn.ui-btn-a:visited { background-color: rgb(78, 155, 216); color: rgb(255, 255, 255); text-shadow: none; }

.ui-page-theme-a .ui-btn:hover, html .ui-bar-a .ui-btn:hover, html .ui-body-a .ui-btn:hover, html body .ui-group-theme-a .ui-btn:hover, html head + body .ui-btn.ui-btn-a:hover { background-color: rgb(237, 237, 237); border-color: rgb(221, 221, 221); color: rgb(51, 51, 51); text-shadow: none; }

.ui-input-search input { padding-left: 2.4em; font-size: 0.9em; }

.ui-input-search.ui-input-has-clear .ui-btn.ui-input-clear, .ui-input-text.ui-input-has-clear .ui-btn.ui-input-clear { top: 60%; }

.ui-page-theme-a .ui-btn:hover, html .ui-bar-a .ui-btn:hover, html .ui-body-a .ui-btn:hover, html body .ui-group-theme-a .ui-btn:hover, html head + body .ui-btn.ui-btn-a:hover { background-color: rgb(185, 218, 244); color: rgb(51, 51, 51); }

.ui-body-a, .ui-page-theme-a .ui-body-inherit, html .ui-bar-a .ui-body-inherit, html .ui-body-a .ui-body-inherit, html body .ui-group-theme-a .ui-body-inherit, html .ui-panel-page-container-a { margin-top: 0px; text-shadow: none; }

.ui-header, .ui-footer { border-width: 0px; border-style: none; position: relative; }

.ui-filterable { margin-top: 5px; }

#avisos { text-align: center; color: red; font-size: 1.2em; line-height: 1.7em; padding-bottom: 10px; font-weight: bold; }

#erro { position: fixed; top: 0px; width: 100%; height: 100%; z-index: 10; overflow: hidden; }

#erro img { max-height: 100%; max-width: 100%; width: auto; height: auto; position: absolute; inset: 0px; margin: auto; }

p#rodape { text-align: center; }

.avisoErro { text-align: center; font-size: 16px; color: rgb(153, 0, 0); margin-top: 15px; margin-bottom: 15px; font-weight: bold; line-height: 18px; padding-bottom: 15px; }

.erro { color: rgb(153, 0, 0); }

table#tabResult tbody tr:nth-child(2n+1) { background-color: rgb(239, 239, 239); border-top: 1px dotted rgb(204, 204, 204); }

table#tabResult tr td { border-top: 1px dotted rgb(204, 204, 204); }

.ui-collapsible-inset.ui-collapsible-themed-content .ui-collapsible-content { border-bottom-left-radius: 5px; border-bottom-right-radius: 5px; }

.ui-collapsible-content > .ui-listview { border-bottom-left-radius: 5px; border-bottom-right-radius: 5px; }

.ui-listview > .ui-li-static.ui-last-child, .ui-listview > .ui-li-divider.ui-last-child, .ui-listview > li.ui-last-child > a.ui-btn { border-bottom-width: 0px; }

.ui-listview > .ui-li-static, .ui-listview > .ui-li-divider, .ui-listview > li > a.ui-btn { border-width: 0px; }

.ui-icon-myicon::after { background-image: url("../resources/css/images/21-skull.png"); background-size: 18px 18px; }

ul#epInfos { margin: 0px; padding: 0px; list-style: none; }

ul#epInfos li { display: block; position: relative; text-align: left; text-overflow: ellipsis; overflow: hidden; white-space: normal; margin: 5px; }

.tit_info { font-weight: bold; padding-top: 10px; border-bottom: 1px dotted rgb(204, 204, 204); color: rgb(102, 153, 204); }

.erroTxt { text-align: center; font-size: 12px; color: rgb(153, 0, 0); margin-top: 15px; margin-bottom: 15px; font-weight: bold; line-height: 18px; }

.txtBlue { color: rgb(102, 153, 204); }

#linhaForma { padding: 5px 5px 5px 0px; height: auto; width: 99%; overflow: auto; color: rgb(102, 153, 204); font-size: 1em; font-weight: bold; margin-top: 15px; }

#linhaTotal label.tx { color: rgb(51, 51, 51); font-weight: normal; }

.spcTop { margin-top: 15px; }

#linhaTotal span.txtTitR { width: 110px; float: right; color: rgb(102, 153, 204); font-size: 1em; font-weight: bold; }

@media (max-width: 300px) {
  body.ui-mobile-viewport, div.ui-mobile-viewport { overflow-x: scroll; }
  .ui-mobile .ui-page { min-height: 420px; overflow-x: scroll; min-width: 320px; }
}

@media print {
  body, input, select, textarea, button, .ui-btn { font-size: 0.5em; line-height: 1.3em; font-family: Arial, Helvetica, sans-serif; color: rgb(0, 0, 0) !important; }
  body { background-color: rgb(255, 255, 255); }
  .sefaz-logo { display: none; }
  div#infos { border: 1px solid rgb(204, 204, 204); background-color: rgb(255, 255, 255); margin-top: 5px; border-radius: 5px; max-width: 408px; }
  div#infos h4 { }
  .ui-btn-icon-left::after, .ui-btn-icon-right::after, .ui-btn-icon-top::after, .ui-btn-icon-bottom::after, .ui-btn-icon-notext::after { display: none; }
  .ui-collapsible-inset, .ui-collapsible-set { margin: 0px; }
  .ui-collapsible-content > .ui-listview { border-bottom-left-radius: 0px; border-bottom-right-radius: 0px; }
  div#infos ul li { border-radius: 5px; }
  h1.tit.ui-title { width: 400px; margin: auto; text-align: left; }
  h1.tit.ui-title p { display: none; }
  h1.tit.ui-title img { height: 40px; width: 56px; position: absolute; top: 40px; }
  div.ui-content div#conteudo div.txtCenter div { width: 345px; margin-left: 53px; }
  .ui-collapsible-inset.ui-collapsible-themed-content .ui-collapsible-content { border-bottom-left-radius: 0px; border-bottom-right-radius: 0px; }
  .ui-collapsible-themed-content .ui-collapsible-content { border-bottom-width: 0px; border-top-style: dotted; border-bottom-style: dotted; border-right: 0px; border-left: 0px; border-radius: 5px; }
  .ui-collapsible-inset.ui-collapsible-themed-content > div.ui-collapsible-content:first-child { border-top-width: 0px; }
  .ui-listview > .ui-li-static { padding: 4px; }
  .ui-listview > .ui-li-static, .ui-listview > .ui-li-divider, .ui-listview > li > a.ui-btn { border-width: 0px; border-style: solid; }
  div#header { display: none; }
  div#containerSis { display: none; }
  .ui-overlay-a, .ui-page-theme-a, .ui-page-theme-a .ui-panel-wrapper { background-color: rgb(255, 255, 255); }
  .ui-bar-a, .ui-page-theme-a .ui-bar-inherit, html .ui-bar-a .ui-bar-inherit, html .ui-body-a .ui-bar-inherit, html body .ui-group-theme-a .ui-bar-inherit { background-color: rgb(255, 255, 255); }
  form.ui-filterable { display: none; }
  .spcTop { margin-top: 0px; }
  #conteudo { border: 1px solid rgb(204, 204, 204); padding: 3px; max-width: 400px; }
  div#footer { display: none; }
  .ui-collapsible-content-collapsed { display: block; }
  .ui-collapsible-content { display: block; }
  #erro { position: absolute; top: 0px; z-index: 1000; height: 400px; overflow: hidden; }
  #erro img { margin-top: 120px; }
  .ui-mobile [data-role="page"], .ui-mobile [data-role="dialog"], .ui-page { min-height: auto !important; position: relative !important; }
  div ul li { break-inside: avoid; }
  table#tabResult tr td { line-height: 1.1em; }
  p#rodape { margin: 0px; }
  #tabResult tr td { padding: 2px; }
  #linhaTotal { padding: 2px 2px 2px 0px; }
  #linhaForma { padding: 2px 2px 2px 0px; margin-top: 0px; }
  div#infos > div > h4 > a { font-size: 1em; border-width: 0px 0px 1px; border-top-style: initial; border-right-style: initial; border-left-style: initial; border-top-color: initial; border-right-color: initial; border-left-color: initial; border-image: initial; border-radius: 0px; padding-left: 5px; color: rgb(51, 51, 51); background-color: rgb(255, 255, 255); padding-top: 0px; padding-bottom: 2px; margin-top: 8px; border-bottom-style: dotted; border-bottom-color: rgb(204, 204, 204); }
  div ul li { break-inside: avoid; }
  table#tabResult > tr > td { break-inside: avoid; }
  #linhaTotal span.txtObs { color: rgb(153, 153, 153); display: block; margin-top: -10px !important; }
  table#tabResult tbody tr:nth-child(2n+1) { background-color: rgb(255, 255, 255); }
  .linhaShade { background: rgb(255, 255, 255); }
  .ui-mobile, .ui-mobile body { height: auto; }
  body { display: block; }
  body.ui-mobile-viewport, div.ui-mobile-viewport { overflow-x: visible; }
}
