.flow.out { transform: translateX(-100%) scale(0.7); animation-name: flowouttoleft; animation-timing-function: ease; animation-duration: 350ms; }

.flow.in { transform: translateX(0px) scale(1); animation-name: flowinfromright; animation-timing-function: ease; animation-duration: 350ms; }

.flow.out.reverse { transform: translateX(100%); animation-name: flowouttoright; }

.flow.in.reverse { animation-name: flowinfromleft; }

@-webkit-keyframes flowouttoleft { 
  0% { transform: translateX(0px) scale(1); }
  60%, 70% { transform: translateX(0px) scale(0.7); }
  100% { transform: translateX(-100%) scale(0.7); }
}

@keyframes flowouttoleft { 
  0% { transform: translateX(0px) scale(1); }
  60%, 70% { transform: translateX(0px) scale(0.7); }
  100% { transform: translateX(-100%) scale(0.7); }
}

@-webkit-keyframes flowouttoright { 
  0% { transform: translateX(0px) scale(1); }
  60%, 70% { transform: translateX(0px) scale(0.7); }
  100% { transform: translateX(100%) scale(0.7); }
}

@keyframes flowouttoright { 
  0% { transform: translateX(0px) scale(1); }
  60%, 70% { transform: translateX(0px) scale(0.7); }
  100% { transform: translateX(100%) scale(0.7); }
}

@-webkit-keyframes flowinfromleft { 
  0% { transform: translateX(-100%) scale(0.7); }
  30%, 40% { transform: translateX(0px) scale(0.7); }
  100% { transform: translateX(0px) scale(1); }
}

@keyframes flowinfromleft { 
  0% { transform: translateX(-100%) scale(0.7); }
  30%, 40% { transform: translateX(0px) scale(0.7); }
  100% { transform: translateX(0px) scale(1); }
}

@-webkit-keyframes flowinfromright { 
  0% { transform: translateX(100%) scale(0.7); }
  30%, 40% { transform: translateX(0px) scale(0.7); }
  100% { transform: translateX(0px) scale(1); }
}

@keyframes flowinfromright { 
  0% { transform: translateX(100%) scale(0.7); }
  30%, 40% { transform: translateX(0px) scale(0.7); }
  100% { transform: translateX(0px) scale(1); }
